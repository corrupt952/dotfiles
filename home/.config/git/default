[core]
  editor = vim
  quotepath = false
  precomposeunicode = true
  whitespace=fix, -index-with-non-tab,trailing-space,cr-at-eol
  hooksPath = ~/.config/git/hooks

[color]
  ui = true
  diff = true
  branch = true
  interactive = true
  status = true

[color "branch"]
  current = red
  local = white
  remote = yellow

[init]
  defaultBranch = main

[push]
  default = nothing
  autoSetupRemote = true

[fetch]
  prune = true

[rerere]
  enabled = true
  autoupdate = true

[rebase]
  autoSquash = true

[merge]
  conflictstyle = zdiff3

[diff]
  algorithm = patience

[ssh]
  variant = ssh
