{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "outputStyle": "Global Rules",
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "~/.claude/output-styles"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/wezterm-notify.sh" }] }
    ],
    "Notification": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/wezterm-notify.sh" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/wezterm-notify.sh" }] }
    ],
    "StopFailure": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/wezterm-notify.sh" }] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/wezterm-notify.sh" }] }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'TaskCompleted blocked: user has not approved this task as complete. Do not mark tasks complete unilaterally.' >&2; exit 2"
          }
        ]
      }
    ]
  }
}
